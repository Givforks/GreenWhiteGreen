# Hot_Cold_World Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenWeather API Key (optional)
# Get your key from: https://openweathermap.org/api
# If not set, the app uses the free wttr.in fallback
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# AWS Configuration (for AWS Fargate deployment)
# These are typically set via AWS Secrets Manager or ECS Task Definition
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
